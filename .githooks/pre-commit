#!/usr/bin/env bash
set -euo pipefail

STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$' || true)

if [ -z "$STAGED_PHP_FILES" ]; then
	exit 0
fi

echo "Running PHPCS on staged files..."
if ! echo "$STAGED_PHP_FILES" | xargs vendor/bin/phpcs --standard=phpcs.xml.dist; then
	echo ""
	echo "PHPCS found issues. Please review (non-blocking)."
fi

echo ""
echo "Running PHPStan on staged files..."
if ! echo "$STAGED_PHP_FILES" | xargs vendor/bin/phpstan analyse --no-progress; then
	echo ""
	echo "PHPStan found issues. Please review (non-blocking)."
fi

echo ""
echo "Pre-commit checks complete."
